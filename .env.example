# ==============================================================================
# Red Team Agent — Local Environment Configuration Template
# Copy this file to .env and fill in your details.
# ==============================================================================

# Gemini API Model Configuration (Default)
# ------------------------------------------------------------------------------
# Default model names used by Google Generative AI SDK
GEMINI_PRO_MODEL=gemini-2.0-flash
GEMINI_FLASH_MODEL=gemini-2.0-flash

# Provide your Gemini API key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Model Configuration (Optional alternative to bypass Gemini quotas)
# ------------------------------------------------------------------------------
# If you provide a Groq API key, the system will automatically run all analyses
# on Groq's low-latency models instead of Gemini.
# Get a key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Frontend Configuration (Vite)
# ------------------------------------------------------------------------------
# URL of the backend API for frontend client requests.
# Default for local development is http://localhost:8080 or using Vite proxy.
VITE_API_URL=http://localhost:8080
